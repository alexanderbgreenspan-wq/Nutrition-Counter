<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Nutrition Tracker</title>
<style>
  :root {
    --bg: #0f0f0f;
    --surface: #1a1a1a;
    --surface2: #242424;
    --border: #333;
    --text: #f0f0f0;
    --muted: #888;
    --accent: #4a9eff;
    --green: #4caf50;
    --yellow: #ffb300;
    --red: #f44336;
    --radius: 10px;
    --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: var(--font); min-height: 100vh; }

  /* NAV */
  nav { display: flex; background: var(--surface); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; }
  nav button { flex: 1; padding: 14px 4px; background: none; border: none; color: var(--muted); font-size: 12px; cursor: pointer; border-bottom: 2px solid transparent; transition: all .2s; }
  nav button.active { color: var(--accent); border-bottom-color: var(--accent); }

  /* SCREENS */
  .screen { display: none; padding: 16px; max-width: 600px; margin: 0 auto; }
  .screen.active { display: block; }

  /* CARDS */
  .card { background: var(--surface); border-radius: var(--radius); padding: 16px; margin-bottom: 12px; border: 1px solid var(--border); }
  .card-title { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 10px; }

  /* INPUTS */
  input, select, textarea { background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; color: var(--text); font-size: 16px; padding: 10px 12px; width: 100%; outline: none; font-family: var(--font); }
  input:focus, select:focus { border-color: var(--accent); }
  label { display: block; font-size: 13px; color: var(--muted); margin-bottom: 4px; }

  /* BUTTONS */
  .btn { display: block; width: 100%; padding: 13px; border-radius: 8px; border: none; font-size: 16px; font-weight: 600; cursor: pointer; transition: opacity .2s; }
  .btn:active { opacity: .7; }
  .btn-primary { background: var(--accent); color: #fff; }
  .btn-secondary { background: var(--surface2); color: var(--text); border: 1px solid var(--border); }
  .btn-sm { font-size: 13px; padding: 7px 12px; width: auto; display: inline-block; }
  .btn-danger { background: var(--red); color: #fff; }

  /* ALERTS */
  .alert { border-radius: 8px; padding: 12px; margin-bottom: 10px; font-size: 14px; font-weight: 500; }
  .alert-green { background: #1b3d1e; border: 1px solid var(--green); color: var(--green); }
  .alert-yellow { background: #3d2f00; border: 1px solid var(--yellow); color: var(--yellow); }
  .alert-red { background: #3d0f0f; border: 1px solid var(--red); color: var(--red); }

  /* TODAY STATS */
  .stats-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 12px; }
  .stat-box { background: var(--surface2); border-radius: 8px; padding: 12px; text-align: center; }
  .stat-val { font-size: 24px; font-weight: 700; }
  .stat-label { font-size: 11px; color: var(--muted); margin-top: 2px; }
  .stat-sub { font-size: 11px; color: var(--muted); }

  /* PROGRESS BAR */
  .prog-wrap { margin-bottom: 10px; }
  .prog-label { display: flex; justify-content: space-between; font-size: 12px; color: var(--muted); margin-bottom: 4px; }
  .prog-bar { height: 6px; background: var(--surface2); border-radius: 3px; overflow: hidden; }
  .prog-fill { height: 100%; border-radius: 3px; transition: width .3s; }

  /* TABLE */
  .tbl-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 14px; }
  th { background: var(--surface2); padding: 10px 8px; text-align: right; color: var(--muted); font-size: 11px; font-weight: 600; text-transform: uppercase; border-bottom: 1px solid var(--border); white-space: nowrap; }
  th:first-child { text-align: left; }
  td { padding: 10px 8px; text-align: right; border-bottom: 1px solid var(--border); }
  td:first-child { text-align: left; }
  tr.today-row td { background: #1a2433; }
  tr.summary-row td { background: var(--surface2); font-weight: 700; font-size: 13px; color: var(--accent); border-top: 2px solid var(--accent); }
  .dot-open { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--accent); margin-left: 4px; vertical-align: middle; }

  /* MEAL LOG LIST */
  .meal-item { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid var(--border); }
  .meal-item:last-child { border-bottom: none; }
  .meal-name { font-size: 14px; font-weight: 500; }
  .meal-macros { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .meal-del { background: none; border: none; color: var(--red); font-size: 18px; cursor: pointer; padding: 4px 8px; }

  /* SEARCH RESULTS */
  .search-item { padding: 12px; border-bottom: 1px solid var(--border); cursor: pointer; }
  .search-item:hover { background: var(--surface2); }
  .search-item-name { font-size: 14px; font-weight: 500; }
  .search-item-detail { font-size: 12px; color: var(--muted); margin-top: 2px; }

  /* TABS */
  .tab-row { display: flex; gap: 6px; margin-bottom: 14px; flex-wrap: wrap; }
  .tab { background: var(--surface2); border: 1px solid var(--border); border-radius: 20px; padding: 6px 14px; font-size: 13px; cursor: pointer; color: var(--muted); }
  .tab.active { background: var(--accent); color: #fff; border-color: var(--accent); }

  /* MODAL */
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.7); z-index: 200; display: flex; align-items: flex-end; }
  .modal-overlay.hidden { display: none; }
  .modal { background: var(--surface); border-radius: var(--radius) var(--radius) 0 0; padding: 20px; width: 100%; max-width: 600px; margin: 0 auto; max-height: 85vh; overflow-y: auto; }
  .modal-title { font-size: 17px; font-weight: 700; margin-bottom: 16px; }
  .modal-close { float: right; background: none; border: none; color: var(--muted); font-size: 22px; cursor: pointer; line-height: 1; }

  /* RANGE */
  input[type=range] { padding: 0; background: none; border: none; accent-color: var(--accent); }

  /* UTILITY */
  .row { display: flex; gap: 10px; }
  .row > * { flex: 1; }
  .mt { margin-top: 12px; }
  .mb { margin-bottom: 12px; }
  .text-muted { color: var(--muted); font-size: 13px; }
  .text-green { color: var(--green); }
  .text-yellow { color: var(--yellow); }
  .text-red { color: var(--red); }
  .hidden { display: none !important; }
  .spinner { text-align: center; padding: 20px; color: var(--muted); font-size: 14px; }
  .divider { border: none; border-top: 1px solid var(--border); margin: 14px 0; }
  #setup-banner { background: #1a2d1a; border: 1px solid var(--green); border-radius: var(--radius); padding: 16px; margin-bottom: 16px; font-size: 14px; line-height: 1.6; }
  #setup-banner code { background: #0f0f0f; padding: 2px 6px; border-radius: 4px; font-size: 12px; }
</style>
</head>
