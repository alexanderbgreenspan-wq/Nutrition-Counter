<script>
// ─── SUPABASE INIT ───────────────────────────────────────────────
let sb;
try {
  sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  if (SUPABASE_URL === 'YOUR_SUPABASE_URL') throw new Error('not configured');
} catch(e) {
  document.getElementById('setup-banner').classList.remove('hidden');
}

// ─── STATE ───────────────────────────────────────────────────────
let cfg = { calCeil: 2400, proFloor: 88, proCeil: 168, fatRatio: 1.0 };
let todayDay = null;      // current open day number
let todayMeals = [];      // intraday meals
let historyDays = [];     // locked days from DB
let libMeals = [];        // saved library
let libPending = null;    // meal being re-logged from library
let usdaPending = null;   // selected USDA food

// ─── NAV ─────────────────────────────────────────────────────────
function showScreen(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('nav button').forEach(b => b.classList.remove('active'));
  document.getElementById('screen-' + name).classList.add('active');
  event && event.target && event.target.classList.add('active');
  if (name === 'history') renderHistory();
  if (name === 'log' && name === 'library') renderLibrary();
  if (name === 'today') renderToday();
}
document.querySelectorAll('nav button').forEach((b, i) => {
  b.addEventListener('click', function() {
    document.querySelectorAll('nav button').forEach(x => x.classList.remove('active'));
    this.classList.add('active');
  });
});

// ─── SETTINGS ────────────────────────────────────────────────────
async function loadSettings() {
  if (!sb) return;
  const { data } = await sb.from('settings').select('*');
  if (!data) return;
  data.forEach(r => {
    if (r.key === 'calCeil') cfg.calCeil = +r.value;
    if (r.key === 'proFloor') cfg.proFloor = +r.value;
    if (r.key === 'proCeil') cfg.proCeil = +r.value;
    if (r.key === 'fatRatio') cfg.fatRatio = +r.value;
  });
  document.getElementById('s-cal-ceil').value = cfg.calCeil;
  document.getElementById('s-pro-floor').value = cfg.proFloor;
  document.getElementById('s-pro-ceil').value = cfg.proCeil;
  document.getElementById('s-fat-ratio').value = +(cfg.fatRatio * 100).toFixed(0);
}

async function saveSettings() {
  cfg.calCeil = +document.getElementById('s-cal-ceil').value;
  cfg.proFloor = +document.getElementById('s-pro-floor').value;
  cfg.proCeil = +document.getElementById('s-pro-ceil').value;
  cfg.fatRatio = +document.getElementById('s-fat-ratio').value / 100;
  if (!sb) { alert('Supabase not configured.'); return; }
  const rows = [
    { key: 'calCeil', value: String(cfg.calCeil) },
    { key: 'proFloor', value: String(cfg.proFloor) },
    { key: 'proCeil', value: String(cfg.proCeil) },
    { key: 'fatRatio', value: String(cfg.fatRatio) },
  ];
  await sb.from('settings').upsert(rows, { onConflict: 'key' });
  alert('Settings saved.');
  renderToday();
}

// ─── HISTORY LOAD ────────────────────────────────────────────────
async function loadHistory() {
  if (!sb) return;
  const { data } = await sb.from('days').select('*').eq('locked', true).order('id', { ascending: true });
  historyDays = data || [];
  // keep only last 35
  if (historyDays.length > 35) historyDays = historyDays.slice(-35);
}

async function loadTodayMeals() {
  if (!sb || !todayDay) return;
  const { data } = await sb.from('meals_today').select('*').eq('day_id', todayDay).order('logged_at', { ascending: true });
  todayMeals = data || [];
}

async function loadLibrary() {
  if (!sb) return;
  const { data } = await sb.from('library').select('*').order('name', { ascending: true });
  libMeals = data || [];
}

// ─── OPEN DAY DETECTION ──────────────────────────────────────────
async function detectOpenDay() {
  if (!sb) return;
  const { data } = await sb.from('days').select('*').eq('locked', false).maybeSingle();
  if (data) {
    todayDay = data.id;
    await loadTodayMeals();
  }
}

// ─── WEIGH-IN / DAY LOCK ─────────────────────────────────────────
async function submitWeighIn() {
  const w = parseFloat(document.getElementById('weight-input').value);
  const dayNum = parseInt(document.getElementById('day-number-input').value);
  if (!w || !dayNum) { alert('Please enter weight and day number.'); return; }
  if (!sb) { alert('Supabase not configured.'); return; }

  // Lock yesterday if open
  if (todayDay !== null && todayDay !== dayNum) {
    const totalCal = todayMeals.reduce((s, m) => s + m.calories, 0);
    const totalPro = todayMeals.reduce((s, m) => s + m.protein, 0);
    await sb.from('days').update({
      calories: Math.round(totalCal),
      protein: Math.round(totalPro),
      locked: true
    }).eq('id', todayDay);
    // clear intraday meals for yesterday (optional: keep for record)
  }

  // Create today's row
  const today = new Date().toISOString().split('T')[0];
  const { error } = await sb.from('days').upsert({
    id: dayNum,
    date: today,
    weight_kg: w,
    calories: 0,
    protein: 0,
    locked: false
  }, { onConflict: 'id' });

  if (error) { alert('Error: ' + error.message); return; }
  todayDay = dayNum;
  todayMeals = [];

  // Enforce 35-day window: drop old
  await sb.from('days').delete().lt('id', dayNum - 35);

  await loadHistory();
  renderToday();
}

// ─── TODAY RENDER ────────────────────────────────────────────────
function renderToday() {
  const noDay = todayDay === null;
  document.getElementById('weigh-in-card').classList.toggle('hidden', !noDay);
  document.getElementById('today-summary').classList.toggle('hidden', noDay);
  if (noDay) return;

  const totCal = +todayMeals.reduce((s, m) => s + m.calories, 0).toFixed(1);
  const totPro = +todayMeals.reduce((s, m) => s + m.protein, 0).toFixed(1);

  document.getElementById('stat-cal').textContent = totCal;
  document.getElementById('stat-pro').textContent = totPro + 'g';

  // Budget
  const past13 = historyDays.slice(-13).reduce((s, d) => s + (d.calories || 0), 0);
  const budget = 33600 - past13;
  document.getElementById('budget-display').textContent = budget > 0 ? budget + ' kcal' : '⚠️ Over budget';
  document.getElementById('stat-cal-budget').textContent = 'budget: ' + budget;
  document.getElementById('stat-pro-floor').textContent = 'floor: ' + cfg.proFloor + 'g';

  // Progress bars
  const calPct = Math.min((totCal / cfg.calCeil) * 100, 100);
  const proPct = Math.min((totPro / cfg.proCeil) * 100, 100);
  document.getElementById('cal-bar').style.width = calPct + '%';
  document.getElementById('cal-bar').style.background = totCal >= cfg.calCeil ? 'var(--red)' : 'var(--accent)';
  document.getElementById('pro-bar').style.width = proPct + '%';
  document.getElementById('pro-bar').style.background = totPro >= cfg.proCeil ? 'var(--red)' : totPro >= cfg.proFloor ? 'var(--green)' : 'var(--yellow)';
  document.getElementById('cal-label').textContent = totCal + ' / ' + cfg.calCeil;
  document.getElementById('pro-label').textContent = totPro + 'g / ' + cfg.proCeil + 'g';

  // Alerts
  const alerts = [];
  if (totCal >= cfg.calCeil) alerts.push({ type: 'red', msg: '🔴 Calorie ceiling hit (' + cfg.calCeil + ' kcal)' });
  if (totPro >= cfg.proCeil) alerts.push({ type: 'red', msg: '🔴 Protein ceiling hit (' + cfg.proCeil + 'g)' });
  if (totPro >= cfg.proFloor && totPro < cfg.proCeil) alerts.push({ type: 'green', msg: '✅ Protein floor met (' + cfg.proFloor + 'g)' });
  const ac = document.getElementById('alerts-container');
  ac.innerHTML = alerts.map(a => `<div class="alert alert-${a.type}">${a.msg}</div>`).join('');

  // Meals list
  const ml = document.getElementById('meals-list');
  if (todayMeals.length === 0) {
    ml.innerHTML = '<div class="text-muted">No meals logged yet.</div>';
  } else {
    ml.innerHTML = todayMeals.map(m => `
      <div class="meal-item">
        <div>
          <div class="meal-name">${m.name || 'Meal'}</div>
          <div class="meal-macros">${m.calories} kcal · ${m.protein}g protein</div>
        </div>
        <button class="meal-del" onclick="deleteMeal('${m.id}')">×</button>
      </div>`).join('');
  }
}

// ─── MEAL LOGGING ─────────────────────────────────────────────────
async function addMeal(name, cal, pro, saveLib) {
  if (!sb || todayDay === null) { alert('Start today first by entering your morning weight.'); return; }
  cal = +parseFloat(cal).toFixed(1);
  pro = +parseFloat(pro).toFixed(1);
  const { data, error } = await sb.from('meals_today').insert({
    day_id: todayDay, name, calories: cal, protein: pro
  }).select().single();
  if (error) { alert('Error: ' + error.message); return; }
  todayMeals.push(data);
  if (saveLib) {
    await sb.from('library').upsert({ name, calories: cal, protein: pro }, { onConflict: 'name' });
    await loadLibrary();
  }
  renderToday();
}

async function deleteMeal(id) {
  if (!sb) return;
  await sb.from('meals_today').delete().eq('id', id);
  todayMeals = todayMeals.filter(m => m.id !== id);
  renderToday();
}

function logManual() {
  const name = document.getElementById('manual-name').value.trim() || 'Manual entry';
  const cal = document.getElementById('manual-cal').value;
  const pro = document.getElementById('manual-pro').value;
  const save = document.getElementById('manual-save').checked;
  if (!cal && !pro) { alert('Enter calories or protein.'); return; }
  addMeal(name, cal || 0, pro || 0, save);
  document.getElementById('manual-name').value = '';
  document.getElementById('manual-cal').value = '';
  document.getElementById('manual-pro').value = '';
  document.getElementById('manual-save').checked = false;
}

// ─── USDA SEARCH ─────────────────────────────────────────────────
async function searchUSDA() {
  const q = document.getElementById('usda-query').value.trim();
  if (!q) return;
  document.getElementById('usda-results').innerHTML = '<div class="spinner">Searching…</div>';
  document.getElementById('usda-confirm-card').classList.add('hidden');
  try {
    const res = await fetch(`https://api.nal.usda.gov/fdc/v1/foods/search?query=${encodeURIComponent(q)}&pageSize=8&dataType=SR%20Legacy,Survey%20(FNDDS),Foundation`);
    const data = await res.json();
    const foods = data.foods || [];
    if (foods.length === 0) {
      document.getElementById('usda-results').innerHTML = '<div class="text-muted">No results found.</div>';
      return;
    }
    document.getElementById('usda-results').innerHTML = foods.map(f => {
      const cal = (f.foodNutrients || []).find(n => n.nutrientId === 1008 || n.nutrientName?.includes('Energy'))?.value || 0;
      const pro = (f.foodNutrients || []).find(n => n.nutrientId === 1003 || n.nutrientName?.includes('Protein'))?.value || 0;
      return `<div class="search-item" onclick="selectUSDA(${JSON.stringify({ id: f.fdcId, name: f.description, cal, pro, ref: 100 }).replace(/"/g, '&quot;')})">
        <div class="search-item-name">${f.description}</div>
        <div class="search-item-detail">${Math.round(cal)} kcal · ${pro}g protein per 100g</div>
      </div>`;
    }).join('');
  } catch(e) {
    document.getElementById('usda-results').innerHTML = '<div class="text-muted">Search failed. Check internet connection.</div>';
  }
}

function selectUSDA(food) {
  usdaPending = food;
  document.getElementById('usda-confirm-card').classList.remove('hidden');
  document.getElementById('usda-confirm-name').textContent = food.name;
  document.getElementById('usda-serving').value = 100;
  document.getElementById('usda-ref').value = 100;
  document.getElementById('usda-final-cal').value = food.cal.toFixed(1);
  document.getElementById('usda-final-pro').value = food.pro.toFixed(1);
}

function recalcUSDA() {
  if (!usdaPending) return;
  const serving = parseFloat(document.getElementById('usda-serving').value) || 100;
  const ref = usdaPending.ref || 100;
  document.getElementById('usda-final-cal').value = (usdaPending.cal * serving / ref).toFixed(1);
  document.getElementById('usda-final-pro').value = (usdaPending.pro * serving / ref).toFixed(1);
}

function logUSDA() {
  if (!usdaPending) return;
  const name = usdaPending.name;
  const cal = document.getElementById('usda-final-cal').value;
  const pro = document.getElementById('usda-final-pro').value;
  const save = document.getElementById('usda-save').checked;
  addMeal(name, cal, pro, save);
  document.getElementById('usda-confirm-card').classList.add('hidden');
  document.getElementById('usda-results').innerHTML = '';
  document.getElementById('usda-query').value = '';
  usdaPending = null;
}

// ─── LIBRARY ─────────────────────────────────────────────────────
function renderLibrary() {
  const el = document.getElementById('library-list');
  if (libMeals.length === 0) {
    el.innerHTML = '<div class="text-muted">No saved meals yet.</div>';
    return;
  }
  el.innerHTML = libMeals.map(m => `
    <div class="meal-item">
      <div>
        <div class="meal-name">${m.name}</div>
        <div class="meal-macros">${m.calories} kcal · ${m.protein}g protein</div>
      </div>
      <button class="btn btn-primary btn-sm" onclick="openLibModal('${m.id}')">Log</button>
    </div>`).join('');
}

function openLibModal(id) {
  libPending = libMeals.find(m => m.id === id);
  if (!libPending) return;
  document.getElementById('lib-modal-title').textContent = libPending.name;
  document.getElementById('lib-modal-macros').textContent = libPending.calories + ' kcal · ' + libPending.protein + 'g protein (100%)';
  document.getElementById('pct-slider').value = 100;
  updatePctDisplay();
  document.getElementById('lib-modal').classList.remove('hidden');
}

function updatePctDisplay() {
  if (!libPending) return;
  const pct = parseInt(document.getElementById('pct-slider').value);
  document.getElementById('pct-display').textContent = pct + '%';
  const cal = (libPending.calories * pct / 100).toFixed(1);
  const pro = (libPending.protein * pct / 100).toFixed(1);
  document.getElementById('lib-modal-adjusted').textContent = cal + ' kcal · ' + pro + 'g protein';
}

function closeLibModal() {
  document.getElementById('lib-modal').classList.add('hidden');
  libPending = null;
}

function confirmLibLog() {
  if (!libPending) return;
  const pct = parseInt(document.getElementById('pct-slider').value);
  const cal = (libPending.calories * pct / 100).toFixed(1);
  const pro = (libPending.protein * pct / 100).toFixed(1);
  addMeal(libPending.name, cal, pro, false);
  closeLibModal();
}

// ─── LOG TAB SWITCHING ────────────────────────────────────────────
function switchLogTab(tab) {
  document.querySelectorAll('#screen-log .tab').forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
  document.getElementById('log-manual').classList.add('hidden');
  document.getElementById('log-search').classList.add('hidden');
  document.getElementById('log-library').classList.add('hidden');
  document.getElementById('log-' + tab).classList.remove('hidden');
  if (tab === 'library') renderLibrary();
}

// ─── HISTORY RENDER ───────────────────────────────────────────────
function renderHistory() {
  const rows = [...historyDays];
  if (rows.length === 0) {
    document.getElementById('history-body').innerHTML = '<tr><td colspan="4" class="spinner">No data yet.</td></tr>';
    return;
  }

  // 14-day rolling averages (last 14 locked days)
  const last14 = rows.slice(-14);
  const avgCal = last14.reduce((s, d) => s + (d.calories || 0), 0) / last14.length;
  const avgPro = last14.reduce((s, d) => s + (d.protein || 0), 0) / last14.length;

  // TDEE calc
  const window35 = rows.slice(-35);
  const firstW = window35[0]?.weight_kg || 0;
  const lastW = window35[window35.length - 1]?.weight_kg || firstW;
  const kgLost = Math.max(0, firstW - lastW);
  const totalCal = window35.reduce((s, d) => s + (d.calories || 0), 0);
  const days = window35.length;
  const tdee = days > 0 ? Math.round((totalCal + kgLost * cfg.fatRatio * 7700) / days) : 0;

  const tbody = document.getElementById('history-body');
  tbody.innerHTML = rows.map(d => `
    <tr>
      <td>Day ${d.id}</td>
      <td>${d.weight_kg ? d.weight_kg + ' kg' : '—'}</td>
      <td>${d.calories ?? '—'}</td>
      <td>${d.protein != null ? d.protein + 'g' : '—'}</td>
    </tr>`).join('') + `
    <tr class="summary-row">
      <td>TDEE: ${tdee} kcal</td>
      <td>—</td>
      <td>${Math.round(avgCal)}</td>
      <td>${Math.round(avgPro)}g</td>
    </tr>`;
}

// ─── IMPORT ───────────────────────────────────────────────────────
async function importDay() {
  const dayNum = parseInt(document.getElementById('imp-day').value);
  const date = document.getElementById('imp-date').value;
  const w = parseFloat(document.getElementById('imp-weight').value);
  const cal = parseInt(document.getElementById('imp-cal').value);
  const pro = parseFloat(document.getElementById('imp-pro').value);
  if (!dayNum || !date || !w || !cal || !pro) { alert('Fill in all fields.'); return; }
  if (!sb) { alert('Supabase not configured.'); return; }
  const { error } = await sb.from('days').upsert({
    id: dayNum, date, weight_kg: w, calories: cal, protein: pro, locked: true
  }, { onConflict: 'id' });
  const status = document.getElementById('import-status');
  if (error) { status.textContent = 'Error: ' + error.message; return; }
  status.textContent = `✓ Day ${dayNum} imported.`;
  await loadHistory();
}

// ─── INIT ─────────────────────────────────────────────────────────
async function init() {
  await loadSettings();
  await loadHistory();
  await detectOpenDay();
  await loadLibrary();
  renderToday();
}

init();
</script>
